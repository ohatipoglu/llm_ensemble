# Ollama API Sunucu Adresi
OLLAMA_HOST="http://localhost:11434"

# Maksimum Eşzamanlı Model İstek Sınırı (Semafor Limiti)
MAX_CONCURRENT_CALLS=2

# Aşamalı Düşünce Zinciri (CoT) Entegrasyonu
ENABLE_COT=true
COT_MAX_TOKENS=120

# Ollama İstek Zaman Aşımı Süresi (Büyük modellerin yüklenmesi için saniye cinsinden)
OLLAMA_TIMEOUT=300.0

# Ollama Model Bellekte Tutma Süresi (Büyük modellerin VRAM çakışmasını önlemek için "0" hemen siler)
OLLAMA_KEEP_ALIVE="0"

# OpenTelemetry Tracing Entegrasyonu
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=llm_ensemble_arena



